# ============================================================
# Paper Pilot — example env file. Copy to .env in each app dir.
# ============================================================

# --- Shared by api + worker ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/paper-pilot?retryWrites=true&w=majority
REDIS_URL=rediss://default:<token>@<region>.upstash.io:6379
NODE_ENV=development
LOG_LEVEL=info

# --- API only ---
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Worker only ---
WORKER_CONCURRENCY=2
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=60000

# --- Web (Next.js public + server) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
DEEPSEEK_API_KEY=sk-...
