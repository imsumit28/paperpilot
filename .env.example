# ============================================================
# Paper Pilot — example env file. Copy to .env in each app dir.
# ============================================================

# --- Shared by api + worker ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/paper-pilot?retryWrites=true&w=majority

# Railway Redis (replaces Upstash — no per-command billing, unlimited for BullMQ polling)
# Local dev: use the public proxy URL from Railway dashboard → Redis → Connect
# Production (Railway services): use the private URL redis://default:<pass>@redis.railway.internal:6379
REDIS_URL=redis://default:<pass>@<host>.proxy.rlwy.net:<port>

NODE_ENV=development
LOG_LEVEL=info

# --- API only ---
API_PORT=4000

# Comma-separated list of allowed CORS origins.
# Local:      http://localhost:3000
# Production: https://<your-app>.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# --- Worker only ---
WORKER_CONCURRENCY=2
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=60000

# --- Web (Next.js public vars — baked in at build time) ---
# Local:      http://localhost:4000
# Production: https://<your-api>.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
