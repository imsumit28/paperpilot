NODE_ENV=development
API_PORT=4000

# Comma-separated allowed CORS origins.
# Production: https://<your-app>.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/paper-pilot?retryWrites=true&w=majority

# Railway Redis public proxy URL (local dev).
# On Railway itself use the private URL: redis://default:<pass>@redis.railway.internal:6379
REDIS_URL=redis://default:<pass>@<host>.proxy.rlwy.net:<port>

LOG_LEVEL=info
